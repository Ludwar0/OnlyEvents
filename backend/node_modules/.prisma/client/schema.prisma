generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  password          String
  firstName         String
  lastName          String
  phone             String?
  role              String    @default("USER")
  isVerified        Boolean   @default(false)
  verificationToken String?
  resetToken        String?
  resetTokenExpiry  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  events        Event[]   @relation("ClientEvents")
  vendorProfile Vendor?
  reviews       Review[]
  sessions      Session[]
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

model Vendor {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName String
  category     String
  description  String
  location     String
  contactEmail String
  contactPhone String
  rating       Float    @default(0)
  isFeatured   Boolean  @default(false)
  isApproved   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  services VendorService[]
  reviews  Review[]
}

model VendorService {
  id          String   @id @default(uuid())
  vendorId    String
  vendor      Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  name        String
  description String
  price       Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Event {
  id                  String   @id @default(uuid())
  clientId            String
  client              User     @relation("ClientEvents", fields: [clientId], references: [id])
  eventType           String
  customEventType     String?
  eventDate           DateTime
  venue               String
  package             String
  guests              Int
  specialRequirements String?
  totalAmount         Float
  amountPaid          Float    @default(0)
  paymentStatus       String   @default("PENDING")
  status              String   @default("UPCOMING")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  payments        Payment[]
  allocations     EquipmentAllocation[]
  truckAssignment Truck?                @relation(fields: [truckId], references: [id])
  truckId         String?
}

model Equipment {
  id                String   @id @default(uuid())
  name              String
  category          String
  totalQuantity     Int
  availableQuantity Int
  condition         String   @default("Good")
  status            String   @default("AVAILABLE")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  allocations EquipmentAllocation[]
}

model EquipmentAllocation {
  id          String    @id @default(uuid())
  eventId     String
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  quantity    Int
  allocatedAt DateTime  @default(now())
  returnedAt  DateTime?
}

model Truck {
  id          String   @id @default(uuid())
  plateNumber String   @unique
  driverName  String
  driverPhone String
  capacity    String
  status      String   @default("AVAILABLE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  events Event[]
}

model Payment {
  id             String    @id @default(uuid())
  eventId        String
  event          Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  amount         Float
  currency       String    @default("KES")
  method         String
  reference      String?   @unique
  status         String    @default("PENDING")
  stripeIntentId String?   @unique
  receiptUrl     String?
  paidAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Review {
  id        String   @id @default(uuid())
  vendorId  String
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([vendorId, userId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  type      String
  createdAt DateTime @default(now())
}
